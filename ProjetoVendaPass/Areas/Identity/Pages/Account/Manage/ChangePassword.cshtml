@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Alterar Senha";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="vp-page-header">
    <h3 class="vp-page-title">@ViewData["Title"]</h3>
    <p class="vp-page-sub">Mantenha sua conta segura com uma senha forte</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="vp-card vp-form-card">
    <form id="change-password-form" method="post" class="vp-form">
        <div asp-validation-summary="ModelOnly" class="vp-alert vp-alert-danger" role="alert"></div>

        <div class="vp-field">
            <label asp-for="Input.OldPassword" class="vp-label"></label>
            <input asp-for="Input.OldPassword" class="vp-input"
                   autocomplete="current-password" aria-required="true"
                   placeholder="••••••••" />
            <span asp-validation-for="Input.OldPassword" class="vp-error"></span>
        </div>

        <div class="vp-field">
            <label asp-for="Input.NewPassword" class="vp-label"></label>
            <input asp-for="Input.NewPassword" class="vp-input"
                   autocomplete="new-password" aria-required="true"
                   placeholder="••••••••" />
            <span asp-validation-for="Input.NewPassword" class="vp-error"></span>
        </div>

        <div class="vp-field">
            <label asp-for="Input.ConfirmPassword" class="vp-label"></label>
            <input asp-for="Input.ConfirmPassword" class="vp-input"
                   autocomplete="new-password" aria-required="true"
                   placeholder="••••••••" />
            <span asp-validation-for="Input.ConfirmPassword" class="vp-error"></span>
        </div>

        <button type="submit" class="vp-btn vp-btn-primary vp-btn-block">
            Salvar nova senha
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

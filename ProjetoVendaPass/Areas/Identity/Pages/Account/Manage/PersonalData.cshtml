@page
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@model PersonalDataModel
@{
    ViewData["Title"] = "Dados pessoais";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}
    <section class="vp-settings-panel">
        <header class="vp-panel-header">
            <h2 class="vp-panel-title">Dados pessoais</h2>
            <p class="vp-panel-sub">
                Sua conta contém dados pessoais que você nos forneceu.
                Aqui você pode baixar ou excluir esses dados.
            </p>
        </header>

        <div class="vp-alert vp-alert--warning" role="alert">
            <strong>Atenção:</strong> excluir estes dados removerá sua conta
            permanentemente, e essa ação <em>não pode ser desfeita</em>.
        </div>

        <div class="vp-actions-row">
            <form id="download-data" asp-page="DownloadPersonalData" method="post">
                <button class="vp-btn vp-btn--primary" type="submit">
                    <svg class="vp-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                    Baixar meus dados
                </button>
            </form>

            <a class="vp-btn vp-btn--danger" id="delete" asp-page="DeletePersonalData">
                <svg class="vp-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                    <path d="M10 11v6M14 11v6" />
                    <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2" />
                </svg>
                Excluir minha conta
            </a>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

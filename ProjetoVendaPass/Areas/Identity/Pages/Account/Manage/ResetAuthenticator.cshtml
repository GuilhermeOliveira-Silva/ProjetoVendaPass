@page
@model ResetAuthenticatorModel
@{
    ViewData["Title"] = "Redefinir chave do autenticador";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>

<div class="alert alert-warning" role="alert">
    <p>
        <strong>⚠️ Se você redefinir sua chave de autenticador, seu aplicativo autenticador não funcionará até ser reconfigurado.</strong>
    </p>
    <p>
        Este processo desativa o 2FA até que você verifique seu aplicativo autenticador novamente.
        Se não concluir a configuração, você poderá perder o acesso à sua conta.
    </p>
</div>

<div>
    <form id="reset-authenticator-form" method="post">
        <button id="reset-authenticator-button" class="btn btn-danger" type="submit">
            Redefinir chave do autenticador
        </button>
    </form>
</div>
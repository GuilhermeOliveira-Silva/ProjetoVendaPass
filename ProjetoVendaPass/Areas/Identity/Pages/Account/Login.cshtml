@page
@model LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<section class="vp-auth">
    <div class="vp-auth-card">
        <div class="vp-auth-header">
            <div class="vp-auth-badge">🎮 VendaPass</div>
            <h1 class="vp-auth-title">Acesse sua conta</h1>
            <p class="vp-auth-sub">Entre para gerenciar seus planos e pagamentos</p>
        </div>

        <form id="account" method="post" class="vp-auth-form">
            <div asp-validation-summary="ModelOnly" class="vp-alert vp-alert-danger" role="alert"></div>

            <div class="vp-field">
                <label asp-for="Input.Email" class="vp-label"></label>
                <input asp-for="Input.Email" class="vp-input"
                       autocomplete="username" aria-required="true"
                       placeholder="seu@email.com" />
                <span asp-validation-for="Input.Email" class="vp-error"></span>
            </div>

            <div class="vp-field">
                <label asp-for="Input.Password" class="vp-label"></label>
                <input asp-for="Input.Password" class="vp-input"
                       autocomplete="current-password" aria-required="true"
                       placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="vp-error"></span>
            </div>

            <label class="vp-check">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
            </label>

            <button id="login-submit" type="submit" class="vp-btn vp-btn-primary vp-btn-block">
                Entrar →
            </button>

            <div class="vp-auth-links">
                <a id="forgot-password" asp-page="./ForgotPassword">Esqueceu sua senha?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Criar nova conta</a>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Reenviar email de confirmação</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

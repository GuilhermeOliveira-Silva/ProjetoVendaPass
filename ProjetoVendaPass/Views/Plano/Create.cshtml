@model ProjetoVendaPass.Models.Plano

@{
    ViewData["Title"] = "Novo Plano";
}

<h2>Novo Plano</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Preco" class="form-label"></label>
        <input asp-for="Preco" class="form-control" />
        <span asp-validation-for="Preco" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="QuantidadeMoeda" class="form-label"></label>
        <input asp-for="QuantidadeMoeda" class="form-control" />
        <span asp-validation-for="QuantidadeMoeda" class="text-danger"></span>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Ativo" class="form-check-input" />
        <label asp-for="Ativo" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-success">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
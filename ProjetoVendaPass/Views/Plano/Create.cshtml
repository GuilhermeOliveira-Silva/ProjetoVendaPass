@model ProjetoVendaPass.Models.Plano

@{
    ViewData["Title"] = "Novo Plano";
}

<div class="container py-4" style="max-width:680px;">

    <div class="vp-page-header">
        <h1 style="color:#fff; font-weight:800; margin:0;">＋ Novo Plano</h1>
        <div style="color:var(--vp-text-muted); margin-top:.35rem;">
            Adicione um novo passe à loja.
        </div>
    </div>

    <div class="vp-detail-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="mb-3">
                <label asp-for="Nome" class="vp-label"></label>
                <input asp-for="Nome" class="vp-input" placeholder="Ex.: Pass Premium 30 dias" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Preco" class="vp-label">Preço (R$)</label>
                    <input asp-for="Preco" class="vp-input" placeholder="0,00" />
                    <span asp-validation-for="Preco" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="QuantidadeMoeda" class="vp-label">Qtd. Moedas</label>
                    <input asp-for="QuantidadeMoeda" class="vp-input" placeholder="0" />
                    <span asp-validation-for="QuantidadeMoeda" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-4">
                <label class="vp-check">
                    <input asp-for="Ativo" />
                    <span>Plano ativo (visível na loja)</span>
                </label>
            </div>

            <div style="display:flex; gap:.75rem; flex-wrap:wrap;">
                <button type="submit" class="vp-btn vp-btn-primary">💾 Salvar Plano</button>
                <a asp-action="Index" class="vp-btn vp-btn-ghost">← Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

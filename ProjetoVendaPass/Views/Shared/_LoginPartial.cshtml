@using Microsoft.AspNetCore.Identity
@using ProjetoVendaPass.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav vp-nav-auth">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="vp-nav-user" href="/Identity/Account/Manage/Index" title="Gerenciar conta">
                <span class="vp-nav-avatar">
                    <i class="bi bi-person-fill"></i>
                </span>
                <span class="vp-nav-user-info">
                    <span class="vp-nav-user-label">Olá,</span>
                    <span class="vp-nav-user-name">@User.Identity?.Name</span>
                </span>
            </a>
        </li>
        <li class="nav-item">
            <form class="vp-logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="vp-btn vp-btn-ghost vp-btn-sm" title="Sair">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Sair</span>
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="vp-btn vp-btn-ghost vp-btn-sm" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus"></i>
                <span>Cadastrar</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="vp-btn vp-btn-primary vp-btn-sm" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>Entrar</span>
            </a>
        </li>
    }
</ul>

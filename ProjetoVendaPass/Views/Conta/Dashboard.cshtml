@using X.PagedList.Mvc.Core
@using X.PagedList
@model ProjetoVendaPass.Models.ViewModels.DashboardClienteViewModel

@{
    ViewData["Title"] = "Meu Dashboard";
}

<h2 class="vp-page-title">🏠 Meu Dashboard</h2>
<p class="vp-page-subtitle">Acompanhe suas compras, planos e histórico.</p>

<!-- Cards de resumo -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="vp-stat-card">
            <div class="vp-stat-value info">@Model.TotalCompras</div>
            <div class="vp-stat-label">🛒 Total de Compras</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="vp-stat-card">
            <div class="vp-stat-value success">R$ @Model.TotalGasto.ToString("F2")</div>
            <div class="vp-stat-label">💰 Total Gasto</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="vp-stat-card">
            @if (Model.UltimaCompra != null)
            {
                <div class="vp-stat-value accent" style="font-size: 1.5rem;">
                    @Model.UltimaCompra.Plano?.Nome
                </div>
                <div class="vp-stat-label" style="margin-bottom:.5rem;">
                    @Model.UltimaCompra.DataCompra.ToString("dd/MM/yyyy HH:mm")
                </div>
                @if (Model.UltimaCompra.Status == ProjetoVendaPass.Models.StatusCompra.Pago)
                {
                    <span class="vp-badge vp-badge-success">✅ Pago</span>
                }
                else
                {
                    <span class="vp-badge vp-badge-pending">⏳ Pendente</span>
                }
                <div class="vp-stat-label" style="margin-top:.75rem;">📦 Última Compra</div>
            }
            else
            {
                <div class="vp-stat-value" style="font-size: 1.25rem; opacity:.6;">—</div>
                <div class="vp-stat-label">📦 Nenhuma compra ainda</div>
            }
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="vp-card mb-4">
    <h5 class="vp-section-title" style="margin-top:0;">🔍 Filtrar Compras</h5>
    <form asp-action="Dashboard" method="get">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="vp-label">Status</label>
                <select name="filtroStatus" class="vp-select">
                    <option value="">Todos</option>
                    <option value="Pendente" selected="@(Model.FiltroStatus == "Pendente")">⏳ Pendente</option>
                    <option value="Pago" selected="@(Model.FiltroStatus == "Pago")">✅ Pago</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="vp-label">Plano</label>
                <input type="text" name="filtroPLano" value="@Model.FiltroPlano"
                       class="vp-input" placeholder="Ex: 1 milhão" />
            </div>
            <div class="col-md-3">
                <label class="vp-label">De</label>
                <input type="date" name="filtroDataInicio"
                       value="@Model.FiltroDataInicio?.ToString("yyyy-MM-dd")"
                       class="vp-input" />
            </div>
            <div class="col-md-3">
                <label class="vp-label">Até</label>
                <input type="date" name="filtroDataFim"
                       value="@Model.FiltroDataFim?.ToString("yyyy-MM-dd")"
                       class="vp-input" />
            </div>
        </div>
        <div class="mt-3 d-flex gap-2 flex-wrap">
            <button type="submit" class="vp-btn vp-btn-primary">🔍 Filtrar</button>
            <a asp-action="Dashboard" class="vp-btn vp-btn-ghost">✖ Limpar Filtros</a>
        </div>
    </form>
</div>

<!-- Tabela -->
<h4 class="vp-section-title">
    📋 Compras
    @if (Model.ComprasRecentes.Any())
    {
        <small style="font-size:.85rem; font-weight:400;">
            (@Model.ComprasRecentes.TotalItemCount resultado(s) —
            página @Model.ComprasRecentes.PageNumber de @Model.ComprasRecentes.PageCount)
        </small>
    }
</h4>

@if (!Model.ComprasRecentes.Any())
{
    <div class="vp-alert">
        Nenhuma compra encontrada.
        <a asp-action="Dashboard" class="alert-link">Limpar filtros</a>
    </div>
}
else
{
    <div class="vp-table-wrap">
        <table class="vp-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Plano</th>
                    <th>Valor</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th style="width:1%; white-space:nowrap;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var compra in Model.ComprasRecentes)
                {
                    <tr>
                        <td>@compra.Id</td>
                        <td><strong>@compra.Plano?.Nome</strong></td>
                        <td>R$ @compra.ValorPago.ToString("F2")</td>
                        <td>@compra.DataCompra.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            @if (compra.Status == ProjetoVendaPass.Models.StatusCompra.Pago)
                            {
                                <span class="vp-badge vp-badge-success">✅ Pago</span>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <span class="vp-badge vp-badge-pending">⏳ Pendente</span>
                                    <a asp-controller="Loja"
                                       asp-action="Pagamento"
                                       asp-route-id="@compra.Id"
                                       class="vp-btn vp-btn-sm vp-btn-primary">
                                        Finalizar
                                    </a>
                                </div>
                            }
                        </td>
                        <td>
                            <a asp-controller="Loja"
                               asp-action="Detalhes"
                               asp-route-id="@compra.Id"
                               class="vp-btn vp-btn-sm">
                                🔍 Ver
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginação -->
    <div class="d-flex justify-content-center mt-4">
        @Html.PagedListPager(Model.ComprasRecentes, pagina => Url.Action("Dashboard", new
        {
            pagina,
        filtroStatus = Model.FiltroStatus,
        filtroDataInicio = Model.FiltroDataInicio?.ToString("yyyy-MM-dd"),
        filtroDataFim = Model.FiltroDataFim?.ToString("yyyy-MM-dd"),
        filtroPLano = Model.FiltroPlano
        }),
        new PagedListRenderOptions
        {
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
            UlElementClasses = new[] { "pagination" },
            ActiveLiElementClass = "active",
            DisplayLinkToFirstPage = PagedListDisplayMode.Never,
            DisplayLinkToLastPage = PagedListDisplayMode.Never,
        })
</div>
}

<!-- Links rápidos -->
<div class="mt-4 d-flex gap-2 flex-wrap">
    <a asp-action="Index" class="vp-btn">👤 Minha Conta</a>
    <a asp-controller="Loja" asp-action="Index" class="vp-btn vp-btn-primary">🛒 Ver Planos</a>
    <a asp-action="AlterarSenha" class="vp-btn vp-btn-danger">🔒 Alterar Senha</a>
</div>

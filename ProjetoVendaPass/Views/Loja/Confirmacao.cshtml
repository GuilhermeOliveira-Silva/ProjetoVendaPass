@model ProjetoVendaPass.Models.Compra

@{
    ViewData["Title"] = "Pagamento Confirmado";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-md-9">

        <div class="vp-success-hero text-center">
            <div class="vp-success-ring">
                <div class="vp-success-check">✓</div>
            </div>
            <h1 class="vp-success-title">Pagamento <span class="vp-text-accent">Confirmado!</span></h1>
            <p class="vp-success-sub">Sua compra foi processada com sucesso. Aproveite!</p>
        </div>

        <div class="vp-detail-card mt-4">
            <div class="vp-detail-header">
                <div>
                    <span class="vp-eyebrow">📋 Resumo</span>
                    <h2 class="vp-detail-title">Pedido <span class="vp-text-accent">#@Model.Id</span></h2>
                </div>
                <span class="vp-badge vp-badge-success">✅ Pago</span>
            </div>

            <div class="vp-detail-body">
                <div class="vp-detail-row">
                    <span class="vp-detail-label">Plano</span>
                    <span class="vp-detail-value fw-semibold">@Model.Plano?.Nome</span>
                </div>
                <div class="vp-detail-row">
                    <span class="vp-detail-label">Moedas</span>
                    <span class="vp-detail-value">🪙 @Model.Plano?.QuantidadeMoeda.ToString("N0")</span>
                </div>
                <div class="vp-detail-row">
                    <span class="vp-detail-label">Valor Pago</span>
                    <span class="vp-detail-value vp-text-accent fw-bold fs-4">
                        R$ @Model.ValorPago.ToString("F2")
                    </span>
                </div>
                <div class="vp-detail-row">
                    <span class="vp-detail-label">Data</span>
                    <span class="vp-detail-value">@Model.DataCompra.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>

            <div class="vp-detail-footer">
                <a asp-action="MinhasCompras" class="vp-btn vp-btn-ghost">
                    🛒 Minhas Compras
                </a>
                <a asp-action="Index" class="vp-btn vp-btn-primary">
                    🏠 Voltar à Loja
                </a>
            </div>
        </div>

    </div>
</div>

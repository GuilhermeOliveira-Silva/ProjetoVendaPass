@model ProjetoVendaPass.Models.Compra

@{
    ViewData["Title"] = "Aguardando Pagamento";
}

<div class="text-center mt-5">

    <div class="display-1 mb-3">⏳</div>

    <h1 class="fw-bold">Pedido Recebido!</h1>
    <p class="text-muted fs-5">Seu pedido foi registrado e está aguardando pagamento.</p>

    <div class="card shadow-sm mx-auto mt-4" style="max-width: 450px;">
        <div class="card-body text-start">

            <h5 class="card-title fw-bold mb-3">📋 Resumo do Pedido</h5>

            <dl class="row">
                <dt class="col-5">Plano:</dt>
                <dd class="col-7">@Model.Plano?.Nome</dd>

                <dt class="col-5">Valor:</dt>
                <dd class="col-7 text-success fw-bold">R$ @Model.ValorPago.ToString("F2")</dd>

                <dt class="col-5">Data:</dt>
                <dd class="col-7">@Model.DataCompra.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-5">Status:</dt>
                <dd class="col-7">
                    <span class="badge bg-warning text-dark">⏳ @Model.Status</span>
                </dd>

                <dt class="col-5">Nº do Pedido:</dt>
                <dd class="col-7">#@Model.Id</dd>
            </dl>

        </div>
    </div>

    <div class="alert alert-info mt-4 mx-auto" style="max-width: 450px;">
        📩 Em breve você receberá as instruções de pagamento.
    </div>

    <a asp-controller="Loja" asp-action="Index" class="btn btn-outline-secondary mt-3">
        ← Voltar à Loja
    </a>

</div>
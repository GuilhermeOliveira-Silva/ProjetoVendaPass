@model IEnumerable<ProjetoVendaPass.Models.Plano>

@{
    ViewData["Title"] = "Loja de Passes";
}

<div class="text-center mb-5">
    <h1 class="display-5 fw-bold">🎮 Loja de Passes</h1>
    <p class="text-muted">Escolha o melhor pacote para você e aproveite!</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        Nenhum plano disponível no momento. Volte em breve!
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
        @foreach (var plano in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center d-flex flex-column">

                        <h5 class="card-title fw-bold fs-4">@plano.Nome</h5>

                        <p class="text-muted mb-1">
                            <i class="bi bi-coin"></i>
                            @plano.QuantidadeMoeda.ToString("N0") moedas
                        </p>

                        <div class="my-3">
                            <span class="fs-2 fw-bold text-success">
                                R$ @plano.Preco.ToString("F2")
                            </span>
                        </div>

                        <div class="mt-auto">
                            <form asp-action="Comprar" asp-controller="Loja" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="planoId" value="@plano.Id" />
                                <button type="submit" class="btn btn-success w-100 fw-bold">
                                    🛒 Comprar
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}
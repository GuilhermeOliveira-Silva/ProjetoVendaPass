@{
    ViewData["Title"] = "Home";
}

<section class="vp-hero">
    <div class="vp-hero__inner">
        <span class="vp-hero__badge">
            <span class="vp-hero__badge-dot"></span>
            Plataforma oficial de passes de jogos
        </span>

        <h1 class="vp-hero__title">
            Seu próximo <span class="vp-hero__title-accent">game pass</span>
            entregue em segundos.
        </h1>

        <p class="vp-hero__subtitle">
            Compre passes, créditos e cartões de jogos com pagamento seguro,
            entrega instantânea e o melhor preço do mercado.
        </p>

        <div class="vp-hero__cta">
            <a href="/Loja" class="vp-btn vp-btn--primary">Explorar Loja →</a>
            <a href="#como-funciona" class="vp-hero__link">Como funciona</a>
        </div>
    </div>

    <!-- Carrossel infinito de stats -->
    <div class="vp-stats-marquee" aria-hidden="false">
        <div class="vp-stats-marquee__track">
            <!-- Grupo 1 -->
            <div class="vp-stat-card"><div class="vp-stat-card__value">+50k</div><div class="vp-stat-card__label">Clientes ativos</div></div>
            <div class="vp-stat-card"><div class="vp-stat-card__value">99.9%</div><div class="vp-stat-card__label">Entregas no prazo</div></div>
            <div class="vp-stat-card"><div class="vp-stat-card__value">24/7</div><div class="vp-stat-card__label">Suporte ativo</div></div>
            <div class="vp-stat-card"><div class="vp-stat-card__value">100%</div><div class="vp-stat-card__label">Pagamento seguro</div></div>
            <div class="vp-stat-card"><div class="vp-stat-card__value">+1M</div><div class="vp-stat-card__label">Pedidos entregues</div></div>
            <div class="vp-stat-card"><div class="vp-stat-card__value">+200</div><div class="vp-stat-card__label">Jogos disponíveis</div></div>
            <div class="vp-stat-card"><div class="vp-stat-card__value">4.9★</div><div class="vp-stat-card__label">Avaliação média</div></div>
            <div class="vp-stat-card"><div class="vp-stat-card__value">&lt;30s</div><div class="vp-stat-card__label">Tempo de entrega</div></div>

            <!-- Grupo 2 (DUPLICADO — necessário para loop infinito sem corte) -->
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">+50k</div><div class="vp-stat-card__label">Clientes ativos</div></div>
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">99.9%</div><div class="vp-stat-card__label">Entregas no prazo</div></div>
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">24/7</div><div class="vp-stat-card__label">Suporte ativo</div></div>
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">100%</div><div class="vp-stat-card__label">Pagamento seguro</div></div>
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">+1M</div><div class="vp-stat-card__label">Pedidos entregues</div></div>
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">+200</div><div class="vp-stat-card__label">Jogos disponíveis</div></div>
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">4.9★</div><div class="vp-stat-card__label">Avaliação média</div></div>
            <div class="vp-stat-card" aria-hidden="true"><div class="vp-stat-card__value">&lt;30s</div><div class="vp-stat-card__label">Tempo de entrega</div></div>
        </div>
    </div>
</section>


<section class="vp-section">
    <div class="vp-section-head">
        <h2>Por que escolher a <span class="vp-accent">VendaPass</span>?</h2>
        <p>Tudo que você precisa para comprar com confiança e receber na hora.</p>
    </div>

    <div class="vp-grid-3">
        <div class="vp-card">
            <div class="vp-card-icon">⚡</div>
            <h3>Entrega instantânea</h3>
            <p>Receba seu código ou pass no e-mail em segundos após a confirmação do pagamento.</p>
        </div>
        <div class="vp-card">
            <div class="vp-card-icon">🔒</div>
            <h3>Pagamento blindado</h3>
            <p>Transações criptografadas e processadas pelas maiores gateways do mercado.</p>
        </div>
        <div class="vp-card">
            <div class="vp-card-icon">💎</div>
            <h3>Melhor preço garantido</h3>
            <p>Acompanhamos o mercado em tempo real para te oferecer sempre o valor mais competitivo.</p>
        </div>
        <div class="vp-card">
            <div class="vp-card-icon">🎮</div>
            <h3>Catálogo completo</h3>
            <p>Passes, créditos e cartões dos seus jogos favoritos — tudo num só lugar.</p>
        </div>
        <div class="vp-card">
            <div class="vp-card-icon">💬</div>
            <h3>Suporte 24/7</h3>
            <p>Atendimento humano e rápido sempre que você precisar, todos os dias da semana.</p>
        </div>
        <div class="vp-card">
            <div class="vp-card-icon">⭐</div>
            <h3>Avaliado pelos gamers</h3>
            <p>Mais de 50 mil clientes satisfeitos e avaliações reais comprovando nossa qualidade.</p>
        </div>
    </div>
</section>
